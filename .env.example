# LLM provider
LLM_PROVIDER=openrouter

# OpenRouter
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini

# Optional tracing
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=multi-agent-research-lab

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Optional web search
TAVILY_API_KEY=

# Runtime
APP_ENV=local
LOG_LEVEL=INFO
MAX_ITERATIONS=6
TIMEOUT_SECONDS=60

# False = real LLM, True = mock
USE_MOCK=False